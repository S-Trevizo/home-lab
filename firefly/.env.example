APP_ENV=production
APP_DEBUG=false
SITE_OWNER=your-email@example.com
APP_KEY=your-32-character-app-key-here
DEFAULT_LANGUAGE=en_US
DEFAULT_LOCALE=equal
TZ=America/Chicago
TRUSTED_PROXIES=**
LOG_CHANNEL=stack
APP_LOG_LEVEL=notice
AUDIT_LOG_LEVEL=emergency
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=firefly
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password
CACHE_DRIVER=file
SESSION_DRIVER=file
STATIC_CRON_TOKEN=your-32-character-cron-token-here
APP_NAME=FireflyIII
BROADCAST_DRIVER=log
QUEUE_DRIVER=sync
CACHE_PREFIX=firefly
FIREFLY_III_LAYOUT=v1
APP_URL=https://firefly.your-domain.com
ALLOW_REGISTRATION=true
